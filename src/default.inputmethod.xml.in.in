<?xml version="1.0" encoding="utf-8"?>
<!-- filename: default.xml -->
<engines>
  <engine>
	<name>smartpinyin</name>
	<language>zh_CN</language>
	<license>GPL</license>
	<author>
	xierongchuan &lt;https://github.com/xierongchuan&gt;
	Peng Wu &lt;alexepico@gmail.com&gt;
	Peng Huang &lt;shawn.p.huang@gmail.com&gt;
	BYVoid &lt;byvoid1@gmail.com&gt;
	</author>
	<icon>@PKGDATADIR@/icons/ibus-pinyin.svg</icon>
	<layout>default</layout>
	<longname>Smart Pinyin</longname>
	<description>Smart Pinyin input method</description>
	<rank>99</rank>
	<symbol>&#x62FC;</symbol>
	@ICON_PROP_KEY_XML@
	<setup>@LIBEXECDIR@/ibus-setup-smartpinyin smartpinyin</setup>
	<version>@VERSION@</version>
	<textdomain>ibus-smartpinyin</textdomain>
  </engine>
  <engine>
	<name>smartbopomofo</name>
	<language>zh_TW</language>
	<license>GPL</license>
	<author>
	xierongchuan &lt;https://github.com/xierongchuan&gt;
	Peng Wu &lt;alexepico@gmail.com&gt;
	Peng Huang &lt;shawn.p.huang@gmail.com&gt;
	BYVoid &lt;byvoid1@gmail.com&gt;
	</author>
	<icon>@PKGDATADIR@/icons/ibus-bopomofo.svg</icon>
	<layout>default</layout>
	<longname>Smart Bopomofo</longname>
	<description>Smart Bopomofo input method</description>
	<rank>98</rank>
	<symbol>&#x3109;</symbol>
	@ICON_PROP_KEY_XML@
	<setup>@LIBEXECDIR@/ibus-setup-smartpinyin smartbopomofo</setup>
	<version>@VERSION@</version>
	<textdomain>ibus-smartpinyin</textdomain>
  </engine>
</engines>
